# =============================================
# SkillBridge Frontend — Environment Variables
# =============================================
# Copy this file to .env and fill in values.
#
# Vite requires env vars to be prefixed with VITE_
# to be exposed to client-side code.
# =============================================

# Backend API base URL.
# Leave empty if frontend and backend are served from the same domain.
# Set to the full backend URL if they are separate, e.g.:
#   VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=