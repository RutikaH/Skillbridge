# ===========================================
# SkillBridge Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in values.
#
# For production, set ALL of these in your
# hosting platform's environment variable panel.
# NEVER commit the .env file to version control.
# ===========================================

# ---------- LLM API Keys ----------
# At least ONE of the two keys below is required for the AI assessment
# to work. The application will start without either key, but model
# calls will fail at runtime.
#
# Recommended for cheapest / simplest deployments: set GROQ_API_KEY only
# (the app will run in "Groq-only" mode and skip OpenAI entirely).
#
# If BOTH keys are set, OpenAI (GPT-4o) is the primary provider and
# Groq is the automatic runtime fallback.

# OPTIONAL — leave empty for a Groq-only deployment.
OPENAI_API_KEY=

# REQUIRED for production — get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# ---------- Database ----------
# SQLite (development):
DATABASE_URL=sqlite:///./skillbridge.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/skillbridge

# ---------- JWT Authentication (required) ----------
# Generate a strong random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ---------- Google OAuth (optional) ----------
# Leave empty to disable Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to your backend's public URL, e.g.:
#   GOOGLE_REDIRECT_URI=https://your-backend.onrender.com/auth/google/callback
GOOGLE_REDIRECT_URI=

# ---------- CORS & Frontend ----------
# The frontend URL the backend allows requests from.
# Set to your deployed frontend URL, e.g.:
#   FRONTEND_URL=https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins.
# Example for production:
#   CORS_ORIGINS=https://your-frontend.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
